{
  "expo": {
    "name": "Blood Donors BD",
    "slug": "blooddonorbd",
    "owner": "passivecoder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "blooddonorsbd",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#7f1d1d"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.passivecoder.blooddonorsbd",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Your location is used to find blood donors near you.",
        "NSCameraUsageDescription": "Take a profile photo for a donor listing.",
        "NSPhotoLibraryUsageDescription": "Choose a profile photo for a donor listing."
      }
    },
    "android": {
      "package": "com.passivecoder.blooddonorsbd",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#b91c1c"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAVEuaPHTeSN0GMpxHIIEpSbjgN-_1om7U"
        }
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Your location is used to find blood donors near you."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Choose a profile photo for a donor listing.",
          "cameraPermission": "Take a profile photo for a donor listing."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#dc2626"
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "apiBase": "https://blood.passivecoder.com",
      "eas": {
        "projectId": "572ce940-25e6-4198-85e8-b8d556b62dad"
      }
    }
  }
}
